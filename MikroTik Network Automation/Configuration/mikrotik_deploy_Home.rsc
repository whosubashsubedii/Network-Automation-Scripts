/ip address add address="10.100.0.1/24" interface="V100-ETH-10" comment="GW VLAN100"

/ip dhcp-client add interface="ether1" add-default-route=yes use-peer-dns=no use-peer-ntp=no disabled=no comment="WAN via DHCP on ether1"

/ip dns set servers="1.1.1.1,8.8.8.8" allow-remote-requests=yes cache-size=4096KiB
/ip dns static add name=router.lan address=10.255.255.1 comment="Router hostname"

/ip pool add name="DHCP_POOL_V92" ranges="10.20.0.10-10.20.0.254" comment="VLAN92 address pool"
/ip dhcp-server add name="DHCP_V92" interface="V92-ETH-2" address-pool="DHCP_POOL_V92" lease-time=30m authoritative=after-2sec-delay disabled=no comment="DHCP server for VLAN92"
/ip dhcp-server network add address="10.20.0.0/24" gateway="10.20.0.1" dns-server="10.20.0.1" comment="VLAN92 DHCP network options"
