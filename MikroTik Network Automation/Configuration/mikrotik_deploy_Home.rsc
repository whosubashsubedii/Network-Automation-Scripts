/ip dhcp-server add name="DHCP_V100" interface="V100-ETH-10" address-pool="DHCP_POOL_V100" lease-time=30m authoritative=after-2sec-delay disabled=no comment="DHCP server for VLAN100"
/ip dhcp-server network add address="10.100.0.0/24" gateway="10.100.0.1" dns-server="10.100.0.1" comment="VLAN100 DHCP network options"

/ip firewall nat add chain=srcnat out-interface-list=WAN action=masquerade comment="NAT: masquerade all LAN VLANs to WAN"

/ip firewall address-list add list=MGMT_ALLOWED address="10.20.0.0/24" comment="Management access: VLAN92 only"

/ip firewall filter add chain=input action=accept connection-state=established,related,untracked comment="INPUT: accept established, related, untracked"
/ip firewall filter add chain=input action=drop connection-state=invalid comment="INPUT: drop invalid connections"
/ip firewall filter add chain=input action=accept protocol=icmp comment="INPUT: accept ICMP (ping/traceroute)"
/ip firewall filter add chain=input action=accept in-interface-list=LAN protocol=udp dst-port=67,68 comment="INPUT: accept DHCP from VLAN clients"
/ip firewall filter add chain=input action=accept in-interface-list=LAN protocol=udp dst-port=53 comment="INPUT: accept DNS UDP from LAN"
/ip firewall filter add chain=input action=accept in-interface-list=LAN protocol=tcp dst-port=53 comment="INPUT: accept DNS TCP from LAN"
/ip firewall filter add chain=input action=add-src-to-address-list address-list=SSH_BRUTE address-list-timeout=1d protocol=tcp dst-port=22 connection-state=new src-address-list=!MGMT_ALLOWED comment="INPUT: tag non-MGMT SSH attempts for blocklist"
/ip firewall filter add chain=input action=drop src-address-list=SSH_BRUTE comment="INPUT: drop SSH brute-force sources"
/ip firewall filter add chain=input action=accept src-address-list=MGMT_ALLOWED protocol=tcp dst-port=22 comment="INPUT: allow SSH from MGMT VLAN only"
/ip firewall filter add chain=input action=accept src-address-list=MGMT_ALLOWED protocol=tcp dst-port=8291 comment="INPUT: allow Winbox from MGMT VLAN only"
/ip firewall filter add chain=input action=accept src-address-list=MGMT_ALLOWED protocol=tcp dst-port=80,443 comment="INPUT: allow HTTP/HTTPS mgmt from MGMT VLAN"
/ip firewall filter add chain=input action=drop comment="INPUT: default deny all other input"

/ip firewall filter add chain=forward action=accept connection-state=established,related,untracked comment="FWD: accept established, related, untracked"
/ip firewall filter add chain=forward action=drop connection-state=invalid comment="FWD: drop invalid"
/ip firewall filter add chain=forward action=fasttrack-connection connection-state=established,related hw-offload=yes comment="FWD: FastTrack established/related"
/ip firewall filter add chain=forward action=drop in-interface-list=LAN out-interface-list=LAN comment="FWD: block inter-VLAN traffic"
/ip firewall filter add chain=forward action=accept in-interface-list=LAN out-interface-list=WAN comment="FWD: allow VLAN clients -> WAN"
/ip firewall filter add chain=forward action=drop in-interface-list=WAN comment="FWD: drop unsolicited WAN -> LAN"

/ipv6 firewall address-list add list=bad_ipv6 address=::/128 comment="bad_ipv6: unspecified"
/ipv6 firewall address-list add list=bad_ipv6 address=::1 comment="bad_ipv6: loopback"
/ipv6 firewall address-list add list=bad_ipv6 address=fec0::/10 comment="bad_ipv6: site-local"
/ipv6 firewall address-list add list=bad_ipv6 address=::ffff:0:0/96 comment="bad_ipv6: ipv4-mapped"
/ipv6 firewall address-list add list=bad_ipv6 address=::/96 comment="bad_ipv6: ipv4-compat"
/ipv6 firewall address-list add list=bad_ipv6 address=100::/64 comment="bad_ipv6: discard"
/ipv6 firewall address-list add list=bad_ipv6 address=2001:db8::/32 comment="bad_ipv6: documentation"
/ipv6 firewall address-list add list=bad_ipv6 address=2001:10::/28 comment="bad_ipv6: ORCHID"
/ipv6 firewall address-list add list=bad_ipv6 address=3ffe::/16 comment="bad_ipv6: 6bone"

/ipv6 firewall filter add chain=input action=accept connection-state=established,related,untracked comment="IPv6 INPUT: accept established"
/ipv6 firewall filter add chain=input action=drop connection-state=invalid comment="IPv6 INPUT: drop invalid"
/ipv6 firewall filter add chain=input action=accept protocol=icmpv6 comment="IPv6 INPUT: accept ICMPv6"
/ipv6 firewall filter add chain=input action=accept protocol=udp dst-port=33434-33534 comment="IPv6 INPUT: accept UDP traceroute"
/ipv6 firewall filter add chain=input action=accept protocol=udp dst-port=546 src-address=fe80::/10 comment="IPv6 INPUT: DHCPv6 prefix delegation"
/ipv6 firewall filter add chain=input action=drop in-interface-list=!LAN comment="IPv6 INPUT: drop not from LAN"
/ipv6 firewall filter add chain=forward action=fasttrack-connection connection-state=established,related comment="IPv6 FWD: fasttrack"
/ipv6 firewall filter add chain=forward action=accept connection-state=established,related,untracked comment="IPv6 FWD: accept established"
/ipv6 firewall filter add chain=forward action=drop connection-state=invalid comment="IPv6 FWD: drop invalid"
/ipv6 firewall filter add chain=forward action=drop src-address-list=bad_ipv6 comment="IPv6 FWD: drop bad src"
/ipv6 firewall filter add chain=forward action=drop dst-address-list=bad_ipv6 comment="IPv6 FWD: drop bad dst"
/ipv6 firewall filter add chain=forward action=drop protocol=icmpv6 hop-limit=equal:1 comment="IPv6 FWD: drop hop-limit=1"
/ipv6 firewall filter add chain=forward action=accept protocol=icmpv6 comment="IPv6 FWD: accept ICMPv6"
/ipv6 firewall filter add chain=forward action=drop in-interface-list=!LAN comment="IPv6 FWD: drop not from LAN"

/ip service set telnet disabled=yes
/ip service set ftp disabled=yes
/ip service set www disabled=yes
/ip service set www-ssl disabled=yes
/ip service set api disabled=yes
/ip service set api-ssl disabled=yes
/ip service set winbox address="10.20.0.0/24"
/ip service set ssh address="10.20.0.0/24"

/tool mac-server set allowed-interface-list=LAN
/tool mac-server mac-winbox set allowed-interface-list=LAN
/ip neighbor discovery-settings set discover-interface-list=LAN

/system logging add topics=firewall action=memory comment="Firewall events (short-term memory buffer)"

:delay 1s
/interface bridge set br-lan vlan-filtering=yes

:log info "=== Deployment Import Finished ===";
