:log info "=== Deployment Import Started ===";

/system identity set name="Home"
/system clock set time-zone-name="Asia/Kathmandu"
/system ntp client set enabled=yes
/system ntp client servers add address=pool.ntp.org

/interface list add name=WAN comment="WAN uplinks"
/interface list add name=LAN comment="All internal VLAN L3 interfaces"
/interface list add name=MGMT comment="Management VLAN interface"
/interface list member add list=WAN interface="ether1" comment="INTERNET"

/interface bridge add name=br-lan protocol-mode=rstp vlan-filtering=no auto-mac=yes comment="LAN bridge with VLAN filtering"

/interface bridge port add bridge=br-lan interface="ether2" pvid=92 frame-types=admit-only-untagged-and-priority-tagged comment="Access: VLAN92 -> 10.20.0.0/24"
