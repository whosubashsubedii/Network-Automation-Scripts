/interface bridge port add bridge=br-lan interface="ether10" pvid=100 frame-types=admit-only-untagged-and-priority-tagged comment="Access: VLAN100 -> 10.100.0.0/24"

/interface bridge vlan add bridge=br-lan vlan-ids=92 tagged=br-lan untagged="ether2" comment="VLAN92 untagged on ether2"
/interface bridge vlan add bridge=br-lan vlan-ids=93 tagged=br-lan untagged="ether3" comment="VLAN93 untagged on ether3"
