/interface bridge vlan add bridge=br-lan vlan-ids=100 tagged=br-lan untagged="ether10" comment="VLAN100 untagged on ether10"

/interface vlan add name="V92-ETH-2" interface=br-lan vlan-id=92 comment="L3 VLAN92 gateway interface"
/interface list member add list=LAN interface="V92-ETH-2"
/interface list member add list=MGMT interface="V92-ETH-2"
/interface vlan add name="V93-ETH-3" interface=br-lan vlan-id=93 comment="L3 VLAN93 gateway interface"
/interface list member add list=LAN interface="V93-ETH-3"
