/interface bridge add name=loopback protocol-mode=none comment="Router loopback bridge"
/ip address add address=10.255.255.1/32 interface=loopback comment="Loopback /32 (stable router ID)"
/ip address add address="10.20.0.1/24" interface="V92-ETH-2" comment="GW VLAN92 (MANAGEMENT)"
